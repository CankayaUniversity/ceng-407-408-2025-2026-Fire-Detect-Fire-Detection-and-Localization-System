# ================================================================
# Flame Scope Detector — Ortam Değişkenleri Örneği
# 
# Kullanım:
#   cp .env.example .env
#   .env dosyasını düzenle, sonra: python -m src.main
# ================================================================

# ── Backend bağlantısı ───────────────────────────────────────
BACKEND_BASE_URL=http://localhost:8000
# DETECTOR_API_KEY=gizli-anahtar   # backend'de ayarlandıysa

# ── Tespit modu: "mock" (HSV) veya "cnn" (eğitilmiş model) ──
DETECTOR_MODE=cnn

# ── CNN model dosyası (eğitimden çıkan .pt dosyası) ──────────
# Eğitimden sonra training/fire_model.pt oluşur:
#   cd detector
#   python -m training.train_fire_model --data-dir training/dataset --epochs 30
# Sonra aşağıya tam yolu yaz:
# CNN_MODEL_PATH=training/fire_model.pt

# ── Kameralar (JSON array) ───────────────────────────────────
# 
# Seçenek 1: Yerel webcam (test için)
# DETECTOR_CAMERAS=[{"id":1,"name":"Yerel Webcam","source":"0"}]
#
# Seçenek 2: Arkadaşın RTSP kamerası
#   Arkadaşın bilgisayarında: detector/rtsp_server/start_rtsp.ps1 çalıştır
#   IP adresini öğren (start_rtsp.ps1 çıktısında gösterir)
#
DETECTOR_CAMERAS=[{"id":1,"name":"Arkadas Kamera","source":"rtsp://192.168.1.XXX:8554/webcam"}]
#
# Birden fazla kamera:
# DETECTOR_CAMERAS=[{"id":1,"name":"Kamera 1","source":"rtsp://192.168.1.10:8554/webcam"},{"id":2,"name":"Kamera 2","source":"rtsp://192.168.1.11:8554/webcam"}]
#
# Video dosyasıyla test:
# DETECTOR_CAMERAS=[{"id":1,"name":"Test Video","source":"training/test_fire.mp4"}]

# ── Cooldown (aynı kameradan tekrar incident göndermek için bekleme) ─
COOLDOWN_SECONDS=30

# ── Güven eşiği (CNN modu için) ──────────────────────────────
# Eğitimden sonra training/fire_model.json içinde tavsiye edilen
# threshold yazar. Oradan buraya kopyala.
# Düşük = daha hassas (daha çok false alarm)
# Yüksek = daha az alarm (yangını kaçırabilir)
# FIRE_CONFIDENCE_THRESHOLD=0.55   # cnn_detector.py içinde değiştir

# ── Arka arkaya kaç frame yangın görüntüsü gereksin ──────────
# Tek frame false alarm'ları engeller
DETECTION_CONSECUTIVE_FRAMES=3

# ── Snapshot kaydı ───────────────────────────────────────────
SNAPSHOT_DIR=../snapshots

# ── Mock (HSV) mod ayarları — DETECTOR_MODE=mock ise geçerli ─
# DETECTION_FIRE_RATIO_THRESHOLD=0.005
# DETECTION_MIN_FIRE_AREA_RATIO=0.0
# DETECTION_CONFIDENCE_THRESHOLD=0.1
