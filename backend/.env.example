# Database — SQLite (varsayılan, geçici)
# DATABASE_URL=sqlite+aiosqlite:///./flamescope.db
# DATABASE_URL_SYNC=sqlite:///./flamescope.db

# İleride PostgreSQL'e dönmek için .env'de şunları kullanın:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flamescope
# DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/flamescope

# JWT
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: require this header for POST /incidents/detected (detector service)
# DETECTOR_API_KEY=optional-secret-key
