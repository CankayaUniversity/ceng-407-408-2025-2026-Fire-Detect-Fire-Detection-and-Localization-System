# Local SQLite defaults
# DATABASE_URL=sqlite+aiosqlite:///./flamescope.db
# DATABASE_URL_SYNC=sqlite:///./flamescope.db

# Supabase Postgres for Render/cloud deployment
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:5432/postgres
# DATABASE_URL_SYNC=postgresql://postgres:<password>@<host>:5432/postgres

# JWT
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Require this header for detector-only endpoints.
DETECTOR_API_KEY=change-this-shared-detector-secret

# Supabase Storage for incident snapshots
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=incident-snapshots
SNAPSHOT_UPLOAD_MAX_MB=5
SUPABASE_UPLOAD_TIMEOUT_SECONDS=15

# Firebase Admin SDK
# Local development can use a file path:
FIREBASE_CREDENTIALS_PATH=firebase-adminsdk.json
# Render/cloud should use base64 of the service account JSON instead:
# FIREBASE_CREDENTIALS_JSON_BASE64=base64-encoded-service-account-json
