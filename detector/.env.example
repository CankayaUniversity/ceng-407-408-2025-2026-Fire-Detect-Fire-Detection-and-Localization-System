# Flame Scope detector example config
#
# Usage:
#   copy .env.example .env
#   Edit PUBLIC_SNAPSHOT_BASE_URL if a physical phone must load snapshots.
#   Then run: python -m src.main

BACKEND_BASE_URL=http://localhost:8000
# DETECTOR_API_KEY=optional-secret-key

# Detection mode: yolo uses training/best.pt, mock uses HSV color thresholds.
DETECTOR_MODE=yolo
YOLO_MODEL_PATH=training/best.pt
YOLO_CONFIDENCE_THRESHOLD=0.40
YOLO_IMGSZ=512
YOLO_BATCH_SIZE=4
YOLO_BATCH_WAIT_MS=20

# CNN alternative:
# DETECTOR_MODE=cnn
# CNN_MODEL_PATH=training/fire_model.pt

# Dynamic camera list is fetched from backend /cameras/detector-list.
# Keep this empty unless you intentionally use the legacy static camera config.
# DETECTOR_CAMERAS=[{"id":1,"name":"Local Webcam","source":"rtsp://192.168.1.35:8555/webcam"}]

COOLDOWN_SECONDS=10
DETECTION_CONSECUTIVE_FRAMES=3

# Detector writes files here. Backend serves the repository-level snapshots/
# folder at /snapshots.
SNAPSHOT_DIR=../snapshots

# For physical phones, replace the host with your computer LAN IP.
# Example: http://192.168.1.35:8000/snapshots
PUBLIC_SNAPSHOT_BASE_URL=http://localhost:8000/snapshots
